{
  "name": "marc-protocol-sdk",
  "version": "1.0.0",
  "description": "MARC Protocol SDK — FHE-powered confidential payments for AI agents (ERC-7984, ERC-8004, ERC-8183, x402)",
  "license": "BUSL-1.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "keywords": [
    "fhe",
    "x402",
    "marc-protocol",
    "confidential",
    "payment",
    "ai-agent",
    "erc-7984",
    "erc-8004",
    "erc-8183",
    "zama",
    "fhevm",
    "ethereum",
    "encrypted"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marc-protocol/marc.git",
    "directory": "sdk"
  },
  "homepage": "https://github.com/marc-protocol/marc#readme",
  "bugs": {
    "url": "https://github.com/marc-protocol/marc/issues"
  },
  "author": "Himess",
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "ethers": "^6.16.0"
  },
  "peerDependencies": {
    "@zama-fhe/relayer-sdk": ">=0.4.0",
    "express": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@zama-fhe/relayer-sdk": {
      "optional": true
    },
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
}
